{
  "expo": {
    "name": "Monentry",
    "slug": "monentry",
    "version": "1.3.0",
    "orientation": "portrait",
    "scheme": "monentry",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.monentry.app",
      "appleTeamId": "DTHF364HT2",
      "usesAppleSignIn": true,
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.monentry.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Monentry to scan invite QR codes so you can join a partner or family group."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      },
      "privacyPolicyUrl": "https://hmharoon88.github.io/Monentry/privacy.html",
      "termsOfUseUrl": "https://hmharoon88.github.io/Monentry/terms.html",
      "supportUrl": "https://hmharoon88.github.io/Monentry/support.html"
    },
    "owner": "YOUR_EXPO_ACCOUNT"
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function isHouseholdOwner(householdId) {
      return signedIn() && householdDoc(householdId).data.ownerUid == request.auth.uid;
    }

    function settleLedgerDoc(ledgerId) {
      return get(/databases/$(database)/documents/settleLedgers/$(ledgerId));
    }

    function isSettleParticipant(ledgerId) {
      return signedIn()
        && request.auth.uid in settleLedgerDoc(ledgerId).data.participantIds;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);

      match /transactions/{transactionId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isHouseholdMember(householdId);
      allow delete: if isHouseholdOwner(householdId);

      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if signedIn()
          && (memberId == request.auth.uid || isHouseholdOwner(householdId));
        allow update, delete: if isSelf(memberId) || isHouseholdOwner(householdId);
      }

      match /transactions/{transactionId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }

    match /householdInviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn()
        && (resource.data.ownerUid == request.auth.uid
          || isHouseholdMember(resource.data.householdId));
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /settleLedgers/{ledgerId} {
      allow read: if signedIn()
        && (request.auth.uid in resource.data.participantIds
          || resource.data.status in ['pending', 'active']);
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn()
        && (request.auth.uid in resource.data.participantIds
          || request.auth.uid in request.resource.data.participantIds
          || (resource.data.status == 'pending'
            && resource.data.createdBy != request.auth.uid));
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;

      match /entries/{entryId} {
        allow read, write: if isSettleParticipant(ledgerId);
      }
    }
  }
}

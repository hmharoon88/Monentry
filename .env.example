# Copy to `.env` in the project root and fill in values.

# Firebase (Web app config from Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In (Firebase Console → Authentication → Google → Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Apple Sign-In — required on iOS when Google login is offered (App Store guideline 4.8). Set false only for local dev.
EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED=true

# RevenueCat (Project → API keys) — iOS **public** key, starts with appl_
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_paste_your_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# RevenueCat V2 secret key (sk_…) — only for npm run configure-revenuecat (never commit)
# Dashboard → API keys → + New → Version: V2 (legacy v1 keys will not work)
REVENUECAT_SECRET_API_KEY=

# Metro bundler port (default 8082 — avoids conflict with other projects on 8081)
EXPO_DEV_SERVER_PORT=8082

{
  "name": "monentry",
  "version": "1.3.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082 --host lan",
    "android": "expo run:android --port 8082 --host lan",
    "ios": "DEVELOPER_DIR=\"/Users/haroon/Downloads/Xcode.app/Contents/Developer\" expo run:ios --port 8082 --host lan",
    "xcode": "bash scripts/open-xcode.sh",
    "fix-xcode": "bash scripts/fix-xcode.sh",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "merge-eas-env": "node scripts/merge-env-into-eas-json.js",
    "build:ios": "npm run verify-revenuecat && npm run merge-eas-env && eas build --platform ios --profile production",
    "build:preview": "npm run merge-eas-env && eas build --platform ios --profile preview",
    "build:testflight": "npm run verify-revenuecat && npm run merge-eas-env && eas build --platform ios --profile testflight",
    "submit:testflight": "eas submit --platform ios --profile testflight --latest",
    "testflight": "npm run verify-revenuecat && npm run merge-eas-env && eas build --platform ios --profile testflight --auto-submit",
    "submit:ios": "eas submit --platform ios --profile production",
    "sync-eas-env": "bash scripts/sync-eas-env.sh",
    "verify-revenuecat": "bash scripts/verify-revenuecat.sh",
    "setup-revenuecat": "bash scripts/setup-revenuecat.sh",
    "configure-revenuecat": "node scripts/configure-revenuecat.mjs",
    "prepare-appstore": "bash scripts/prepare-appstore.sh"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^16.0.0",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~56.0.0",
    "css-select": "^5.1.0",
    "css-tree": "^1.1.3",
    "expo": "~56.0.11",
    "expo-apple-authentication": "~56.0.4",
    "expo-auth-session": "~56.0.14",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-modules-core": "^56.0.16",
    "expo-router": "~56.2.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.14.0",
    "idb": "^8.0.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-purchases": "^10.2.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4"
  },
  "private": true
}

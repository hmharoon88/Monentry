{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "environment": "preview",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED": "true"
      }
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true,
      "environment": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "testflight",
        "EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "environment": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED": "true"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleTeamId": "DTHF364HT2",
        "ascAppId": "6781850062"
      }
    },
    "production": {
      "ios": {
        "appleTeamId": "DTHF364HT2",
        "ascAppId": "6781850062"
      }
    }
  }
}
